<Project Sdk="Godot.NET.Sdk/4.6.1">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>TheHollowMen</RootNamespace>
  </PropertyGroup>
  <!-- Suppress CS0618 obsolete warnings from YATI (ParallaxBackground/ParallaxLayer) -->
  <PropertyGroup>
    <NoWarn>$(NoWarn);CS0618</NoWarn>
  </PropertyGroup>
</Project>
