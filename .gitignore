# Godot 4 build artifacts
.godot/
*.translation
*.uid

# Godot export templates (large binaries)
export_presets.cfg

# Imported assets cache (regenerated on import)
.import/
*.import

# Editor logs
logs/

# OS artifacts
.DS_Store
Thumbs.db

# Tileset XCF exports — generated by make export-art (xcf2png flattens *.xcf → *.png)
# Only top-level art/tilesets/*.png are ignored; subdirectory PNGs (third-party) are committed.
# Hand-crafted source PNGs (e.g. placeholder.png) are committed explicitly via negation rules.
/art/tilesets/*.png
!/art/tilesets/placeholder.png
# Tileset build artifacts — generated by make copy-art
/assets/tilesets/*.png
/assets/tilesets/**/*.png